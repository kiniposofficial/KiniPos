{
    "functions": [
        {
            "source": "functions",
            "codebase": "kinipos-logic",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firestore-debug.log"
            ]
        }
    ],
    "firestore": {
        "rules": "firestore.rules"
    },
    "hosting": {
        "public": "build/web",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "flutter": {
        "platforms": {
            "android": {
                "default": {
                    "projectId": "kinipos-official",
                    "appId": "1:1060095869219:android:833e169c19bfdc046d0c96",
                    "fileOutput": "android/app/google-services.json"
                }
            },
            "dart": {
                "lib/firebase_options.dart": {
                    "projectId": "kinipos-official",
                    "configurations": {
                        "android": "1:1060095869219:android:833e169c19bfdc046d0c96"
                    }
                }
            }
        }
    }
}